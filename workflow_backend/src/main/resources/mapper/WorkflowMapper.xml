<?xml version="1.0" encoding="UTF-8" ?>

<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.example.LogicCircuit.mapper.WorkflowMapper">

    <insert id="insertWorkflow"
            parameterType="com.example.LogicCircuit.entity.Workflow">

        INSERT INTO workflow(
            user_id,
            name,
            workflow_json,
            created_at,
            updated_at
        )

        VALUES(
                  #{userId},
                  #{name},
                  #{workflowJson},
                  #{createdAt},
                  #{updatedAt}
              )

    </insert>
    <update id="updateWorkflow"

            parameterType="com.example.LogicCircuit.entity.Workflow">

        UPDATE workflow

        SET

            name = #{name},

            workflow_json = #{workflowJson},

            updated_at = #{updatedAt}

        WHERE id = #{id}

    </update>
    <select id="findById"
            resultType="com.example.LogicCircuit.entity.Workflow">

        SELECT *

        FROM workflow

        WHERE id = #{id}

    </select>
    <select
            id="findByUserId"
            resultType="com.example.LogicCircuit.entity.Workflow">
        SELECT
            id,
            user_id,
            name,
            workflow_json,
            created_at,
            updated_at
        FROM workflow
        WHERE user_id = #{userId}
        ORDER BY updated_at DESC
    </select>
</mapper>